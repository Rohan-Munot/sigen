{
  "extends": "@create-figma-plugin/tsconfig",
  "compilerOptions": {
    "typeRoots": ["node_modules/@figma", "node_modules/@types"],
    "types": ["plugin-typings"],
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "module": "ESNext",
    "moduleResolution": "Bundler",
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
}
